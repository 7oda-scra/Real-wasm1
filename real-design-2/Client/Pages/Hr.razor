@page "/hr"
@attribute [Authorize]

<PageContainer Title="Human Resources" Breadcrumbs="@BuildBreadcrumbs()">
    <MudGrid Spacing="4">
        <MudItem xs="12" md="3" lg="2">
            <MudPaper Elevation="0" Class="rounded-xl hr-nav-shell responsive-surface-padding">
                <MudNavMenu Bordered="true" Color="Color.Primary" Class="mud-width-full hr-nav-menu">
                    @foreach (var navSection in _navigationSections)
                    {
                        <MudNavGroup Title="@navSection.Title" Expanded="true" Icon="@navSection.Icon" Class="hr-nav-menu__group">
                            @foreach (var item in navSection.Items)
                            {
                                <MudNavLink OnClick="@(() => SetActiveForm(item.Key))" Icon="@null" Class="@GetNavLinkCss(item.Key)">
                                    @item.Label
                                </MudNavLink>
                            }
                        </MudNavGroup>
                    }
                </MudNavMenu>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="9" lg="10">
            @switch (_activeForm)
            {
                case HrViewKeys.Sectors:
                    @RenderBasicCrud(
                        _sectors,
                        _sectorDraft,
                        _selectedSector,
                        value => SelectSector(value),
                        "Sectors",
                        "Sector Details",
                        "Select a sector",
                        "Sector ID",
                        "Sector Name")
                    break;

                case HrViewKeys.Departments:
                    @RenderBasicCrud(
                        _departments,
                        _departmentDraft,
                        _selectedDepartment,
                        value => SelectDepartment(value),
                        "Departments",
                        "Department Details",
                        "Select a department",
                        "Department ID",
                        "Department Name")
                    break;

                case HrViewKeys.Sections:
                    @RenderBasicCrud(
                        _sections,
                        _sectionDraft,
                        _selectedSection,
                        value => SelectSection(value),
                        "Sections",
                        "Section Details",
                        "Select a section",
                        "Section ID",
                        "Section Name")
                    break;

                case HrViewKeys.Jobs:
                    @RenderBasicCrud(
                        _jobs,
                        _jobDraft,
                        _selectedJob,
                        value => SelectJob(value),
                        "Positions & Jobs",
                        "Position Details",
                        "Select a position",
                        "Job ID",
                        "Job Title")
                    break;

                case HrViewKeys.Qualifications:
                    @RenderBasicCrud(
                        _qualifications,
                        _qualificationDraft,
                        _selectedQualification,
                        value => SelectQualification(value),
                        "Qualifications",
                        "Qualification Details",
                        "Select a qualification",
                        "Qualification ID",
                        "Qualification Name")
                    break;

                case HrViewKeys.Employees:
                    @RenderEmployeeCrud()
                    break;

                case HrViewKeys.AttendanceSystems:
                    @RenderAttendanceSystemCrud()
                    break;

                case HrViewKeys.Shifts:
                    @RenderShiftCrud()
                    break;

                case HrViewKeys.SalaryItems:
                    @RenderBasicCrud(
                        _salaryItems,
                        _salaryItemDraft,
                        _selectedSalaryItem,
                        value => SelectSalaryItem(value),
                        "Salary Items",
                        "Salary Item Details",
                        "Select a salary item",
                        "Salary Item ID",
                        "Salary Item Name")
                    break;

                case HrViewKeys.OvertimeSettings:
                    @RenderBasicCrud(
                        _overtimeSettings,
                        _overtimeSettingDraft,
                        _selectedOvertimeSetting,
                        value => SelectOvertimeSetting(value),
                        "Overtime Settings",
                        "Overtime Setting Details",
                        "Select an overtime setting",
                        "Overtime Setting ID",
                        "Overtime Setting Name")
                    break;

                case HrViewKeys.SalaryCalculationRules:
                    @RenderBasicCrud(
                        _salaryCalculationRules,
                        _salaryCalculationRuleDraft,
                        _selectedSalaryCalculationRule,
                        value => SelectSalaryCalculationRule(value),
                        "Salary Calculation Rules",
                        "Rule Details",
                        "Select a calculation rule",
                        "Rule ID",
                        "Rule Name")
                    break;

                default:
                    <MudPaper Elevation="0" Class="rounded-xl hr-empty-state responsive-surface-padding-lg">
                        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3" Style="min-height: 24rem;">
                            <div class="hr-placeholder-icon">
                                <MudIcon Icon="@Icons.Material.Filled.Groups2" Size="Size.Large" Style="font-size: 3rem; color: #44abdf;" />
                            </div>
                            <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight: 700; letter-spacing: -0.03em;">
                                Select a section
                            </MudText>
                        </MudStack>
                    </MudPaper>
                    break;
            }
        </MudItem>
    </MudGrid>
</PageContainer>

@code {
    private RenderFragment RenderBasicCrud<T>(
        List<T> items,
        T draft,
        T? selectedItem,
        Action<T?> onSelectedItemChanged,
        string title,
        string detailTitle,
        string emptyDetailTitle,
        string idLabel,
        string nameLabel)
        where T : BaseDto, new()
        => @<DynamicCrudView TItem="T"
                             Title="@title"
                             DetailTitle="@detailTitle"
                             EmptyDetailTitle="@emptyDetailTitle"
                             EmptyDetailText="Choose a row from the grid or use Add to open the detail panel."
                             Items="@items"
                             SelectedItem="@selectedItem"
                             SelectedItemChanged="@(item => onSelectedItemChanged(item))"
                             IsDetailOpen="@_isDetailPanelOpen"
                             IsAdding="@(_isDetailPanelOpen && selectedItem is null)"
                             OnAdd="HandleAdd"
                             OnModify="HandleModify"
                             OnDelete="HandleDelete"
                             OnSave="HandleSave"
                             OnClose="HandleToolbarClose">
                <Columns>
                    <PropertyColumn T="T" TProperty="string" Property="@(item => item.Id)" Title="ID" />
                    <PropertyColumn T="T" TProperty="string" Property="@(item => item.Name)" Title="Name" />
                </Columns>
                <DetailContent>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="draft.Id" Label="@idLabel" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="draft.Name" Label="@nameLabel" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                    </MudGrid>
                </DetailContent>
            </DynamicCrudView>;

    private RenderFragment RenderEmployeeCrud()
        => @<DynamicCrudView TItem="EmployeeRecord"
                             Title="Employees"
                             DetailTitle="Employee Details"
                             EmptyDetailTitle="Select an employee"
                             EmptyDetailText="Choose an employee row or use Add to open a new profile."
                             Items="_employees"
                             SelectedItem="_selectedEmployee"
                             SelectedItemChanged="SelectEmployee"
                             IsDetailOpen="@_isDetailPanelOpen"
                             IsAdding="@(_isDetailPanelOpen && _selectedEmployee is null)"
                             OnAdd="HandleAdd"
                             OnModify="HandleModify"
                             OnDelete="HandleDelete"
                             OnSave="HandleSave"
                             OnClose="HandleToolbarClose">
                <Columns>
                    <PropertyColumn T="EmployeeRecord" TProperty="string" Property="@(employee => employee.Name)" Title="Name" />
                    <PropertyColumn T="EmployeeRecord" TProperty="string" Property="@(employee => employee.Title)" Title="Title" />
                    <PropertyColumn T="EmployeeRecord" TProperty="string" Property="@(employee => employee.Department)" Title="Department" />
                </Columns>
                <DetailContent>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_employeeDraft.Id" Label="Employee ID" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_employeeDraft.Name" Label="Employee Name" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_employeeDraft.Title" Label="Job Title" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_employeeDraft.Email" Label="Email Address" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Email" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="_employeeDraft.Department" Label="Department" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                @foreach (var department in _departments)
                                {
                                    <MudSelectItem T="string" Value="@department.Name">@department.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </DetailContent>
            </DynamicCrudView>;

    private RenderFragment RenderAttendanceSystemCrud()
        => @<DynamicCrudView TItem="AttendanceSystem"
                             Title="Time & Attendance Systems"
                             DetailTitle="Attendance System Details"
                             EmptyDetailTitle="Select a system"
                             EmptyDetailText="Choose an attendance system or use Add to configure a new one."
                             Items="_attendanceSystems"
                             SelectedItem="_selectedAttendanceSystem"
                             SelectedItemChanged="SelectAttendanceSystem"
                             IsDetailOpen="@_isDetailPanelOpen"
                             IsAdding="@(_isDetailPanelOpen && _selectedAttendanceSystem is null)"
                             OnAdd="HandleAdd"
                             OnModify="HandleModify"
                             OnDelete="HandleDelete"
                             OnSave="HandleSave"
                             OnClose="HandleToolbarClose">
                <Columns>
                    <PropertyColumn T="AttendanceSystem" TProperty="string" Property="@(attendanceSystem => attendanceSystem.Id)" Title="ID" />
                    <PropertyColumn T="AttendanceSystem" TProperty="string" Property="@(attendanceSystem => attendanceSystem.Name)" Title="Name" />
                    <TemplateColumn T="AttendanceSystem" Title="Tracking Type">
                        <CellTemplate Context="context">
                            @GetTrackingTypeLabel(context.Item.TrackingType)
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <DetailContent>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_attendanceSystemDraft.Id" Label="Attendance System ID" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_attendanceSystemDraft.Name" Label="Attendance System Name" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Elevation="0" Class="rounded-xl hr-toggle-panel responsive-surface-padding">
                                <MudRadioGroup T="AttendanceTrackingType" @bind-Value="_attendanceSystemDraft.TrackingType" Class="hr-radio-group">
                                    <MudRadio T="AttendanceTrackingType" Value="@AttendanceTrackingType.FingerprintRequired">Fingerprint Required</MudRadio>
                                    <MudRadio T="AttendanceTrackingType" Value="@AttendanceTrackingType.OpenShift">Open Shift</MudRadio>
                                </MudRadioGroup>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </DetailContent>
            </DynamicCrudView>;

    private RenderFragment RenderShiftCrud()
        => @<DynamicCrudView TItem="Shift"
                             Title="Shifts"
                             DetailTitle="Shift Details"
                             EmptyDetailTitle="Select a shift"
                             EmptyDetailText="Choose a shift row or use Add to configure a schedule."
                             Items="_shifts"
                             SelectedItem="_selectedShift"
                             SelectedItemChanged="SelectShift"
                             IsDetailOpen="@_isDetailPanelOpen"
                             IsAdding="@(_isDetailPanelOpen && _selectedShift is null)"
                             OnAdd="HandleAdd"
                             OnModify="HandleModify"
                             OnDelete="HandleDelete"
                             OnSave="HandleSave"
                             OnClose="HandleToolbarClose">
                <Columns>
                    <PropertyColumn T="Shift" TProperty="string" Property="@(shift => shift.Id)" Title="ID" />
                    <PropertyColumn T="Shift" TProperty="string" Property="@(shift => shift.Name)" Title="Name" />
                    <TemplateColumn T="Shift" Title="Attendance System">
                        <CellTemplate Context="context">
                            @GetAttendanceSystemName(context.Item.AttendanceSystemId)
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <DetailContent>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_shiftDraft.Id" Label="Shift ID" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_shiftDraft.Name" Label="Shift Name" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="_shiftDraft.AttendanceSystemId" Label="Attendance System" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                @foreach (var attendanceSystem in _attendanceSystems)
                                {
                                    <MudSelectItem T="string" Value="@attendanceSystem.Id">@attendanceSystem.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudNumericField T="int" @bind-Value="_shiftDraft.WorkingHours" Label="Working Hours" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="24" FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Elevation="0" Class="rounded-xl hr-accent-card responsive-surface-padding">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Starts At</MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.WbSunny" Color="Color.Primary" />
                                </MudStack>
                                <MudTimePicker @bind-Time="_shiftDraft.StartTime" Label="Start time" Variant="Variant.Outlined" Margin="Margin.Dense" AmPm="true" />
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Elevation="0" Class="rounded-xl hr-accent-card responsive-surface-padding">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Ends At</MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.Bedtime" Color="Color.Secondary" />
                                </MudStack>
                                <MudTimePicker @bind-Time="_shiftDraft.EndTime" Label="End time" Variant="Variant.Outlined" Margin="Margin.Dense" AmPm="true" />
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12">
                            <MudPaper Elevation="0" Class="rounded-xl hr-toggle-panel responsive-surface-padding">
                                <MudSwitch T="bool" @bind-Value="_shiftDraft.ClosesNextDay" Label="Closing next day" Color="Color.Primary" />
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </DetailContent>
            </DynamicCrudView>;
}
