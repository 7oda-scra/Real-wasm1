@attribute [Authorize]
@implements IDisposable
@inject IWorkspaceTabService WorkspaceTabs
@inject ISnackbar Snackbar

<PageContainer Title="@EmployeeName" Breadcrumbs="@BuildBreadcrumbs()">
    <MudGrid Spacing="4">
        <MudItem xs="12" lg="8">
            <MudPaper Elevation="1" Class="employee-workspace-card rounded-xl pa-6">
                <MudStack Spacing="4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <div>
                            <MudText Typo="Typo.overline" Class="employee-workspace-card__eyebrow">@EmployeeId</MudText>
                            <MudText Typo="Typo.h5" Class="employee-workspace-card__title">Employee Details</MudText>
                        </div>
                        @if (_isDirty)
                        {
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Circle" Class="rounded-pill">
                                Unsaved draft
                            </MudChip>
                        }
                    </MudStack>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string"
                                          Value="_draft.Id"
                                          ValueChanged="@(value => UpdateDraft(value, next => _draft.Id = next))"
                                          Label="Employee ID"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string"
                                          Value="_draft.Name"
                                          ValueChanged="@(value => UpdateDraft(value, next => _draft.Name = next))"
                                          Label="Employee Name"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string"
                                          Value="_draft.Title"
                                          ValueChanged="@(value => UpdateDraft(value, next => _draft.Title = next))"
                                          Label="Job Title"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string"
                                          Value="_draft.Email"
                                          ValueChanged="@(value => UpdateDraft(value, next => _draft.Email = next))"
                                          Label="Email"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          InputType="InputType.Email"
                                          FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSelect T="string"
                                       Value="_draft.Department"
                                       ValueChanged="@(value => UpdateDraft(value, next => _draft.Department = next))"
                                       Label="Department"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       FullWidth="true">
                                @foreach (var department in _departments)
                                {
                                    <MudSelectItem T="string" Value="@department">@department</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>

                    <MudDivider />

                    <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Class="rounded-pill px-5" OnClick="ResetDraft">
                            Reset Draft
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="rounded-pill px-6" StartIcon="@Icons.Material.Filled.Save" OnClick="SaveDraft">
                            Save
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Elevation="0" Class="employee-workspace-note rounded-xl pa-5">
                <MudStack Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Tab" Class="employee-workspace-note__icon" />
                    <MudText Typo="Typo.h6" Class="employee-workspace-note__title">Workspace persistence demo</MudText>
                    <MudText Typo="Typo.body2" Class="employee-workspace-note__text">
                        Edit these fields, switch to Payroll, Attendance, or HR, then return. Because this tab is kept alive, the unsaved draft remains exactly as you left it.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</PageContainer>

@code {
    private readonly string[] _departments =
    [
        "Technology",
        "Human Resources",
        "Finance",
        "Operations",
        "Customer Success"
    ];

    private EmployeeDetailsDraft _draft = new();
    private EmployeeDetailsDraft _savedSnapshot = new();
    private bool _isDirty;

    [CascadingParameter]
    private WorkspaceTabContext? WorkspaceContext { get; set; }

    [Parameter]
    public string EmployeeId { get; set; } = string.Empty;

    [Parameter]
    public string EmployeeName { get; set; } = string.Empty;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Email { get; set; } = string.Empty;

    [Parameter]
    public string Department { get; set; } = string.Empty;

    protected override void OnInitialized()
    {
        _savedSnapshot = new EmployeeDetailsDraft
        {
            Id = EmployeeId,
            Name = EmployeeName,
            Title = Title,
            Email = Email,
            Department = Department
        };
        _draft = Clone(_savedSnapshot);
    }

    public void Dispose()
    {
        SetDirty(false);
    }

    private List<BreadcrumbItem> BuildBreadcrumbs()
    {
        return
        [
            new("Home", "/"),
            new("Human Resources", "/hr"),
            new("Employee Details", null, disabled: true),
            new(EmployeeName, null, disabled: true)
        ];
    }

    private void UpdateDraft(string? value, Action<string> apply)
    {
        apply(value ?? string.Empty);
        SetDirty(!AreEqual(_draft, _savedSnapshot));
    }

    private void SaveDraft()
    {
        _savedSnapshot = Clone(_draft);
        EmployeeName = _draft.Name;
        SetDirty(false);

        if (WorkspaceContext is not null)
        {
            WorkspaceTabs.UpdateTitle(WorkspaceContext.TabId, $"Employee - {_draft.Name}", _draft.Id);
        }

        Snackbar.Add("Employee draft saved in the workspace.", Severity.Success);
    }

    private void ResetDraft()
    {
        _draft = Clone(_savedSnapshot);
        SetDirty(false);
        Snackbar.Add("Draft reverted to the last saved values.", Severity.Info);
    }

    private void SetDirty(bool isDirty)
    {
        _isDirty = isDirty;

        if (WorkspaceContext is not null)
        {
            WorkspaceTabs.SetDirty(WorkspaceContext.TabId, isDirty);
        }
    }

    private static EmployeeDetailsDraft Clone(EmployeeDetailsDraft source)
    {
        return new EmployeeDetailsDraft
        {
            Id = source.Id,
            Name = source.Name,
            Title = source.Title,
            Email = source.Email,
            Department = source.Department
        };
    }

    private static bool AreEqual(EmployeeDetailsDraft left, EmployeeDetailsDraft right)
    {
        return left.Id == right.Id &&
               left.Name == right.Name &&
               left.Title == right.Title &&
               left.Email == right.Email &&
               left.Department == right.Department;
    }

    private sealed class EmployeeDetailsDraft
    {
        public string Id { get; set; } = string.Empty;

        public string Name { get; set; } = string.Empty;

        public string Title { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string Department { get; set; } = string.Empty;
    }
}
