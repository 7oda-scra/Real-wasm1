@page "/"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider
@inject IModuleService ModuleService
@inject NavigationManager NavigationManager

<PageContainer Title="@($"{_greeting}, {_displayName}!")">
    @if (_isLoading)
    {
        <div class="d-flex align-center justify-center" style="height: 60vh;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            @_errorMessage
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.body1" Style="color: #6b7280;">@_dateString</MudText>

        @if (_modules.Count == 0)
        {
            <div class="d-flex justify-center mt-8">
                <MudAlert Severity="Severity.Info" Style="max-width: 520px;">
                    No modules have been assigned to your account. Please contact your administrator.
                </MudAlert>
            </div>
        }
        else
        {
            <MudGrid Spacing="6">
                @foreach (var module in _modules)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <MudCard Elevation="0" Class="bento-card rounded-xl pa-4">
                            <div @onclick="() => NavigationManager.NavigateTo(module.Route)" style="cursor: pointer; height: 100%;" class="d-flex flex-column align-center justify-center pa-6">
                                <div class="icon-badge mb-4" style="@($"width: 72px; height: 72px; background-color: {module.HexColor}1A;")">
                                    <MudIcon Icon="@module.IconPath" Style="@($"color: {module.HexColor}; font-size: 2.5rem;")" />
                                </div>
                                <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight: 600; letter-spacing: -0.5px;">@module.Name</MudText>
                            </div>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    }
</PageContainer>

@code {
    private bool _isLoading = true;
    private string _displayName = "User";
    private string _greeting = "Good morning";
    private string _dateString = string.Empty;
    private string? _errorMessage;
    private List<ModuleDefinitionDto> _modules = [];

    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.Now;
        _greeting = now.Hour < 12 ? "Good morning" : now.Hour < 17 ? "Good afternoon" : "Good evening";
        _dateString = now.ToString("dddd, MMMM d, yyyy");

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                _displayName = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                    ?? user.FindFirst("FullName")?.Value
                    ?? "User";

                _modules = (await ModuleService.GetAllowedModulesAsync()).ToList();
            }
        }
        catch
        {
            _errorMessage = "The dashboard could not load your assigned modules. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
