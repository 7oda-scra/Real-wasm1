@inherits LayoutComponentBase
@implements IDisposable
@using RealDesign2.Client.Theme
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<MudThemeProvider Theme="@AppTheme.Default" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudBreakpointProvider OnBreakpointChanged="HandleBreakpointChanged" />

<MudLayout>
    <MudAppBar Color="Color.Primary" Elevation="4" Class="app-shell__appbar">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="app-shell__brand">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" Class="app-shell__menu-trigger" OnClick="ToggleDrawer" />
            <img src="assets/main-logo.png" alt="Smart Code Logo" class="app-shell__logo" />
        </MudStack>
        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                @if (_currentUser is not null)
                {
                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent Context="menuActivator">
                            <MudAvatar Color="Color.Secondary" Class="app-shell__avatar">
                                @GetAvatarInitial()
                            </MudAvatar>
                        </ActivatorContent>
                        <ChildContent>
                            <MudMenuItem OnClick="LogoutAsync" Disabled="_isLoggingOut">
                                @(_isLoggingOut ? "Signing out..." : "Sign Out")
                            </MudMenuItem>
                        </ChildContent>
                    </MudMenu>
                }
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               Elevation="1"
               ClipMode="DrawerClipMode.Always"
               Class="app-shell__drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="app-shell__body-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool _drawerOpen;
    private bool _isLoggingOut;
    private UserDto? _currentUser;
    private Breakpoint _currentBreakpoint = Breakpoint.Xs;
    private bool _hasResolvedBreakpoint;

    protected override void OnInitialized()
    {
        _currentUser = AuthService.CurrentUser;
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private void HandleAuthStateChanged(UserDto? user)
    {
        _currentUser = user;
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetAvatarInitial()
    {
        if (string.IsNullOrWhiteSpace(_currentUser?.FullName))
        {
            return "?";
        }

        return _currentUser.FullName[..1].ToUpperInvariant();
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void HandleBreakpointChanged(Breakpoint breakpoint)
    {
        _currentBreakpoint = breakpoint;

        if (!_hasResolvedBreakpoint)
        {
            _drawerOpen = !IsMobileBreakpoint(breakpoint);
            _hasResolvedBreakpoint = true;
        }
        else if (!IsMobileBreakpoint(breakpoint) && !_drawerOpen)
        {
            _drawerOpen = true;
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!IsMobileBreakpoint(_currentBreakpoint))
        {
            return;
        }

        _drawerOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    private static bool IsMobileBreakpoint(Breakpoint breakpoint)
    {
        return breakpoint is Breakpoint.Xs or Breakpoint.Sm;
    }

    private async Task LogoutAsync()
    {
        _isLoggingOut = true;

        try
        {
            await AuthService.LogoutAsync();
            NavigationManager.NavigateTo("/login", forceLoad: false);
        }
        finally
        {
            _isLoggingOut = false;
        }
    }
}
