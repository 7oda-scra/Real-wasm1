@implements IDisposable
@inject IModuleService ModuleService
@inject IAuthService AuthService
@inject IWorkspaceTabService WorkspaceTabs

<MudNavMenu Class="app-nav-menu">
    <MudNavLink Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home"
                Class="@GetRootLinkClass()"
                OnClick="OpenDashboard">
        Home
    </MudNavLink>

    @if (_isLoading)
    {
        <MudText Typo="Typo.caption" Class="px-4 py-2" Style="color: #6b7280;">Loading modules...</MudText>
    }
    else if (_allowedModules.Count > 0)
    {
        <MudNavGroup Title="Modules" Expanded="true" Icon="@Icons.Material.Filled.Apps" Class="app-nav-menu__group">
            @foreach (var module in _allowedModules)
            {
                <MudNavLink Match="NavLinkMatch.All"
                            Icon="@module.IconPath"
                            Class="@GetModuleLinkClass(module.Route)"
                            OnClick="@(() => OpenModule(module))">
                    @module.Name
                </MudNavLink>
            }
        </MudNavGroup>
    }
</MudNavMenu>

@code {
    private bool _isLoading = true;
    private List<ModuleDefinitionDto> _allowedModules = [];

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        WorkspaceTabs.Changed += HandleWorkspaceChanged;
        await LoadModulesAsync();
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
        WorkspaceTabs.Changed -= HandleWorkspaceChanged;
    }

    private void HandleAuthStateChanged(UserDto? user)
    {
        _ = InvokeAsync(async () =>
        {
            await LoadModulesAsync();
            StateHasChanged();
        });
    }

    private async Task LoadModulesAsync()
    {
        if (AuthService.CurrentUser is null)
        {
            _allowedModules = [];
            _isLoading = false;
            return;
        }

        _isLoading = true;

        try
        {
            _allowedModules = (await ModuleService.GetAllowedModulesAsync()).ToList();
        }
        catch
        {
            _allowedModules = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenDashboard()
    {
        WorkspaceTabs.OpenOrActivate(WorkspaceTabCatalog.Dashboard());
    }

    private void OpenModule(ModuleDefinitionDto module)
    {
        WorkspaceTabs.OpenOrActivate(WorkspaceTabCatalog.ForModule(module.Name, module.Route, module.IconPath));
    }

    private string GetRootLinkClass()
    {
        return WorkspaceTabs.ActiveTab?.Id == "dashboard:home"
            ? "app-nav-menu__link mud-nav-link-active"
            : "app-nav-menu__link";
    }

    private string GetModuleLinkClass(string route)
    {
        var activeRoute = WorkspaceTabs.ActiveTab?.Route?.Split('?', '#')[0];
        var normalizedRoute = route.StartsWith('/') ? route : $"/{route}";

        return string.Equals(activeRoute, normalizedRoute, StringComparison.OrdinalIgnoreCase)
            ? "app-nav-menu__child-link mud-nav-link-active"
            : "app-nav-menu__child-link";
    }

    private void HandleWorkspaceChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
