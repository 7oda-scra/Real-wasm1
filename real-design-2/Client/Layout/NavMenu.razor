@implements IDisposable
@inject IModuleService ModuleService
@inject IAuthService AuthService

<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>

    @if (_isLoading)
    {
        <MudText Typo="Typo.caption" Class="px-4 py-2" Style="color: #6b7280;">Loading modules...</MudText>
    }
    else if (_allowedModules.Count > 0)
    {
        <MudNavGroup Title="Modules" Expanded="true" Icon="@Icons.Material.Filled.Apps">
            @foreach (var module in _allowedModules)
            {
                <MudNavLink Href="@module.Route" Match="NavLinkMatch.All" Icon="@module.IconPath">@module.Name</MudNavLink>
            }
        </MudNavGroup>
    }
</MudNavMenu>

@code {
    private bool _isLoading = true;
    private List<ModuleDefinitionDto> _allowedModules = [];

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        await LoadModulesAsync();
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
    }

    private void HandleAuthStateChanged(UserDto? user)
    {
        _ = InvokeAsync(async () =>
        {
            await LoadModulesAsync();
            StateHasChanged();
        });
    }

    private async Task LoadModulesAsync()
    {
        if (AuthService.CurrentUser is null)
        {
            _allowedModules = [];
            _isLoading = false;
            return;
        }

        _isLoading = true;

        try
        {
            _allowedModules = (await ModuleService.GetAllowedModulesAsync()).ToList();
        }
        catch
        {
            _allowedModules = [];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
