<PageContainer Title="Page not found">
    <MudPaper Elevation="0" Class="workspace-empty-state rounded-xl pa-8">
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Class="workspace-empty-state__icon" />
            <MudText Typo="Typo.h5" Class="workspace-empty-state__title">This workspace route is not registered</MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Class="workspace-empty-state__text">
                The URL was opened inside the workspace, but no module has been mapped to it yet.
            </MudText>
        </MudStack>
    </MudPaper>
</PageContainer>
