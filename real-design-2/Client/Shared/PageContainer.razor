<section class="page-container">
    <div class="page-container__content">
        <MudStack Spacing="4">
            <div class="page-container__header">
                @if (Breadcrumbs is not null && Breadcrumbs.Count > 0)
                {
                    <MudBreadcrumbs Items="Breadcrumbs" Class="page-container__breadcrumbs" Separator="/">
                        <ItemTemplate Context="item">
                            <MudLink Href="@item.Href"
                                     Disabled="@item.Disabled"
                                     Typo="Typo.body2"
                                     Class="page-container__breadcrumb-link">
                                @item.Text
                            </MudLink>
                        </ItemTemplate>
                    </MudBreadcrumbs>
                }

                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <MudText Typo="Typo.h4" Class="page-container__title">@Title</MudText>
                }
            </div>

            @if (ChildContent is not null)
            {
                @ChildContent
            }
        </MudStack>
    </div>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public List<BreadcrumbItem> Breadcrumbs { get; set; } = [];
}
