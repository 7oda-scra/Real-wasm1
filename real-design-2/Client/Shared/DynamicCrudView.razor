@using MudBlazor
@using System.Reflection
@typeparam TItem where TItem : class

<div class="dynamic-crud-view__workspace">
    <div class="dynamic-crud-view__primary">
        <MudPaper Elevation="1" Class="rounded-xl dynamic-crud-view__table-shell responsive-surface-padding">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="mb-4 dynamic-crud-view__heading">
                <MudText Typo="Typo.h5" Class="dynamic-crud-view__title">@Title</MudText>
            </MudStack>

            <MudDataGrid T="TItem"
                         Items="Items"
                         Hover="true"
                         Striped="true"
                         Dense="false"
                         Filterable="true"
                         SortMode="SortMode.Multiple"
                         ColumnResizeMode="ResizeMode.Column"
                         HorizontalScrollbar="true"
                         Breakpoint="Breakpoint.None"
                         ReadOnly="true"
                         Outlined="false"
                         Elevation="1"
                         QuickFilter="MatchesQuickSearch"
                         SelectOnRowClick="true"
                         SelectedItem="SelectedItem"
                         SelectedItemChanged="HandleSelectedItemChanged"
                         RowClick="HandleRowClick"
                         Class="dynamic-crud-view__grid"
                         Style="width: 100%;">
                <ToolBarContent>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2" Class="dynamic-crud-view__toolbar">
                        <FormActionToolbar
                            OnAdd="HandleAdd"
                            OnModify="HandleModify"
                            OnDelete="HandleDelete"
                            ShowSave="false"
                            ShowClose="false"
                            DisableModify="@(SelectedItem is null)"
                            DisableDelete="@(SelectedItem is null)"
                            Justify="Justify.FlexStart" />

                        <MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2" Class="dynamic-crud-view__toolbar-search-cluster">
                            <MudTextField T="string"
                                          @bind-Value="_searchText"
                                          Placeholder="@ResolvedSearchPlaceholder"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          Clearable="true"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          InputType="InputType.Search"
                                          Class="dynamic-crud-view__search" />

                            @if (ToolBarEndContent is not null)
                            {
                                @ToolBarEndContent
                            }
                        </MudStack>
                    </MudStack>
                </ToolBarContent>

                <Columns>
                    @Columns
                </Columns>

                <PagerContent>
                    <MudDataGridPager T="TItem"
                                      PageSizeSelector="true"
                                      PageSizeOptions="_pageSizeOptions"
                                      InfoFormat="{first_item}-{last_item} of {all_items}" />
                </PagerContent>
            </MudDataGrid>
        </MudPaper>
    </div>

    @if (IsDetailPanelVisible)
    {
        <aside class="dynamic-crud-view__secondary">
            <MudCard Elevation="2" Class="dynamic-crud-view__detail-card pa-6 rounded-lg">
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               Class="dynamic-crud-view__detail-close"
                               OnClick="OnClose" />

                <MudStack Spacing="3" Class="dynamic-crud-view__detail-frame">
                    <MudStack Spacing="1" Class="dynamic-crud-view__detail-header">
                        <MudText Typo="Typo.h6" Class="dynamic-crud-view__detail-title">@DetailTitle</MudText>
                        @if (!string.IsNullOrWhiteSpace(DetailSubtitle))
                        {
                            <MudText Typo="Typo.body2" Class="dynamic-crud-view__detail-subtitle">@DetailSubtitle</MudText>
                        }
                    </MudStack>

                    @if (DetailContent is not null)
                    {
                        <div class="dynamic-crud-view__detail-body">
                            @DetailContent
                        </div>
                    }

                    <MudDivider />

                    <FormActionToolbar
                        OnSave="OnSave"
                        ShowAdd="false"
                        ShowModify="false"
                        ShowDelete="false"
                        ShowSave="true"
                        ShowClose="false"
                        DisableSave="@(!IsDetailPanelVisible)"
                        Justify="Justify.FlexEnd" />
                </MudStack>
            </MudCard>
        </aside>
    }
</div>

@code {
    private readonly int[] _pageSizeOptions = [10, 25, 50, 100];
    private readonly Lazy<PropertyInfo[]> _searchableProperties = new(() => typeof(TItem)
        .GetProperties(BindingFlags.Instance | BindingFlags.Public)
        .Where(property => property.CanRead && property.GetIndexParameters().Length == 0)
        .ToArray());
    private bool IsDetailPanelVisible => IsDetailOpen;
    private string _searchText = string.Empty;
    private string ResolvedSearchPlaceholder => string.IsNullOrWhiteSpace(SearchPlaceholder)
        ? $"Search {Title.ToLowerInvariant()}"
        : SearchPlaceholder;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string DetailTitle { get; set; } = "Details";

    [Parameter]
    public string DetailSubtitle { get; set; } = string.Empty;

    [Parameter]
    public string EmptyDetailTitle { get; set; } = "No item selected";

    [Parameter]
    public string EmptyDetailText { get; set; } = "Click a row in the grid or use Add to open the detail panel.";

    [Parameter]
    public IEnumerable<TItem> Items { get; set; } = Array.Empty<TItem>();

    [Parameter]
    public RenderFragment? Columns { get; set; }

    [Parameter]
    public RenderFragment? DetailContent { get; set; }

    [Parameter]
    public RenderFragment? ToolBarEndContent { get; set; }

    [Parameter]
    public TItem? SelectedItem { get; set; }

    [Parameter]
    public EventCallback<TItem?> SelectedItemChanged { get; set; }

    [Parameter]
    public bool IsDetailOpen { get; set; }

    [Parameter]
    public bool IsAdding { get; set; }

    [Parameter]
    public string SearchPlaceholder { get; set; } = string.Empty;

    [Parameter]
    public Func<TItem, string?>? SearchTextSelector { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnAdd { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnModify { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnDelete { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnSave { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClose { get; set; }

    [Parameter]
    public EventCallback<DataGridRowClickEventArgs<TItem>> OnRowClick { get; set; }

    private async Task HandleAdd(MouseEventArgs args)
    {
        await OnAdd.InvokeAsync(args);
    }

    private async Task HandleModify(MouseEventArgs args)
    {
        await OnModify.InvokeAsync(args);
    }

    private async Task HandleDelete(MouseEventArgs args)
    {
        await OnDelete.InvokeAsync(args);
    }

    private async Task HandleSelectedItemChanged(TItem? item)
    {
        await SelectedItemChanged.InvokeAsync(item);
    }

    private async Task HandleRowClick(DataGridRowClickEventArgs<TItem> args)
    {
        await SelectedItemChanged.InvokeAsync(args.Item);

        if (OnRowClick.HasDelegate)
        {
            await OnRowClick.InvokeAsync(args);
        }
    }

    private bool MatchesQuickSearch(TItem item)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var searchTerm = _searchText.Trim();

        if (SearchTextSelector is not null &&
            SearchTextSelector(item)?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true)
        {
            return true;
        }

        foreach (var property in _searchableProperties.Value)
        {
            if (property.GetValue(item)?.ToString()?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true)
            {
                return true;
            }
        }

        return false;
    }
}
